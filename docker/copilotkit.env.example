# CopilotKit service environment — copy to .env and fill real values.
# Place at: /home/marwanelzaher/ai-company/copilotkit/.env  (chmod 600)

# ── Container image ───────────────────────────────────────────────────────────
# Full GHCR image reference (without tag); reconciler appends the tag.
GHCR_IMAGE=ghcr.io/marwanelzaher/maros-lab-starter

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://rfp.marwanelzaher.info

# ── Cloudflare Access JWT validation ─────────────────────────────────────────
# Audience tag from the CF Access application (output by cf-rfp-access-setup.sh).
# Used by the RBAC middleware to validate CF-Access-JWT-Assertion headers.
CF_ACCESS_AUD=96ffadb0c5a00a21904960e833c7cff8a10351997d700785ac154403632694b1
CF_ACCESS_TEAM_DOMAIN=marwanelzaher.cloudflareaccess.com

# ── Database (Postgres — audit trail + user/session metadata) ─────────────────
DATABASE_URL=postgresql://rfp_user:CHANGEME@postgres:5432/rfp

# ── LangGraph / n8n webhook ───────────────────────────────────────────────────
# Internal docker-network address of the n8n webhook for RFP analysis trigger.
N8N_RFP_WEBHOOK_URL=http://n8n:5678/webhook/rfp-analyze

# ── RAGflow ───────────────────────────────────────────────────────────────────
RAGFLOW_BASE_URL=https://ragflow.marwanelzaher.info
RAGFLOW_API_KEY=your_ragflow_api_key_here

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
