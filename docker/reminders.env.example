# Copy to .env.reminders and fill in real values before deploying.
# Pass to docker compose with: --env-file .env.reminders

# ── WAHA ─────────────────────────────────────────────────────────────────────
# Strong random secret shared between WAHA and n8n (X-Api-Key header).
WAHA_API_KEY=changeme_use_openssl_rand_hex_32

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Create a tunnel in the Cloudflare dashboard, route reminders.marwanelzaher.info
# → http://waha:3000, then paste the tunnel token here.
CF_TUNNEL_TOKEN_REMINDERS=your_cloudflare_tunnel_token_here

# ── n8n Postgres credential (used inside the n8n workflow, not Docker) ────────
# These values are configured directly in n8n as a "Postgres" credential;
# they are listed here for reference only.
#
# DB_HOST=localhost (or your Supabase host)
# DB_PORT=5432
# DB_NAME=your_database
# DB_USER=your_user
# DB_PASS=your_password

# ── Owner alert WhatsApp number ───────────────────────────────────────────────
# E.164 format WITHOUT the leading +  (e.g. 201234567890 for +20 123 456 7890)
# Used by n8n to send failure alerts to the business owner via WAHA.
OWNER_WHATSAPP_NUMBER=201234567890
