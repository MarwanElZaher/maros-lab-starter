// Maro's LAB starter schema
// Run: npx prisma migrate dev --name init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth.js adapter tables)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// RBAC (Cloudflare Access — email-keyed users + roles)
// ---------------------------------------------------------------------------

enum UserRole {
  presales_engineer
  sales_director
}

model AppUser {
  email       String       @id
  role        UserRole
  createdAt   DateTime     @default(now())
  auditEvents AuditEvent[]

  @@map("app_users")
}

// ---------------------------------------------------------------------------
// RFP Analysis
// ---------------------------------------------------------------------------

model RfpAnalysis {
  id             String   @id @default(cuid())
  rfpId          String   @unique
  submitterEmail String
  clientName     String?
  pdfObjectPath  String
  recommendation Json
  decision       String
  confidence     Int
  redFlagCount   Int
  createdAt      DateTime @default(now())

  // Override columns (MAR-65) — CHECK constraints enforced in migration SQL
  overrideDecision     String   @default("none") @map("override_decision")
  overrideScope        String?  @map("override_scope")
  overrideRationale    String?  @map("override_rationale")
  overrideByUserEmail  String?  @map("override_by_user_email")
  overrideAt           DateTime? @map("override_at")
  citedAnalysisIds     String[] @map("cited_analysis_ids")

  // RAGflow writeback tracking (MAR-67)
  persistedToRagflow   Boolean  @default(false) @map("persisted_to_ragflow")
  ragflowDocId         String?  @map("ragflow_doc_id")

  @@index([submitterEmail])
  @@index([createdAt])
  @@map("rfp_analyses")
}

// ---------------------------------------------------------------------------
// Audit log
// ---------------------------------------------------------------------------

model AuditEvent {
  id        String   @id @default(cuid())
  userEmail String
  action    String
  rfpId     String?
  metadata  Json?
  timestamp DateTime @default(now())

  user AppUser @relation(fields: [userEmail], references: [email])

  @@index([userEmail])
  @@index([timestamp])
  @@map("audit_events")
}
