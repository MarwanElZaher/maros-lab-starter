# ============================================================
# Maro's LAB Engagement — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# Production: copy to /home/marwanelzaher/ai-company/maros-lab-starter/.env (chmod 600)
# ============================================================

# --- Database -----------------------------------------------------------
# Local: postgresql://postgres:postgres@localhost:5432/engagement_dev
# Supabase: copy the "Connection string" from your project settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/engagement_dev

# --- Auth (NextAuth.js) -------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_a_real_secret
NEXTAUTH_URL=http://localhost:3000

# OAuth provider credentials (add the ones you use per engagement)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- AI (Anthropic) ----------------------------------------------------
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Observability -------------------------------------------------------
# Sentry: create a project at sentry.io
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=maros-lab
SENTRY_PROJECT=engagement

# Axiom: create a dataset + API token at axiom.co
NEXT_PUBLIC_AXIOM_DATASET=engagement-logs
AXIOM_TOKEN=xaat-...

# --- n8n integration -----------------------------------------------------
# Internal URL of the n8n intake webhook (reachable via docker network n8n_default)
# Production: http://n8n:5678/webhook/intake-submit
# Local dev:  http://localhost:5678/webhook/intake-submit
N8N_INTAKE_WEBHOOK_URL=http://n8n:5678/webhook/intake-submit

# --- RAGflow (KB admin self-service) -------------------------------------
RAGFLOW_BASE_URL=https://ragflow.marwanelzaher.info
RAGFLOW_API_KEY=ragflow-...
# Dataset IDs — created via RAGflow UI or API (see MAR-17, MAR-63)
RAGFLOW_DATASET_PRODUCTS=ab0dfc483bfb11f18e37b14efee78710
RAGFLOW_DATASET_PRICING=abe9de203bfb11f18e37b14efee78710
RAGFLOW_DATASET_PAST_BIDS=aca85a8a3bfb11f18e37b14efee78710
RAGFLOW_DATASET_LICENSING=b8a9354c3e5911f19a41a18bf4de89c2
RAGFLOW_DATASET_USER_GUIDES=b948c0083e5911f19a41a18bf4de89c2

# --- MinIO (object storage for RFP PDFs) ----------------------------------
# Internal access: http://minio:9000 (via docker network n8n_default)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_generate_a_real_minio_secret
MINIO_BUCKET_RFP=rfp-pdfs

# --- VPS deployment (production .env on VPS only) -----------------------
# GHCR_IMAGE=ghcr.io/<org>/<repo>      # lowercase GitHub org/repo
# APP_HOST=<subdomain.yourdomain.com>  # Traefik routing hostname
# MINIO_CONSOLE_HOST=minio.yourdomain.com  # Traefik routing for MinIO console
